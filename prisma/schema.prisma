// Orient Roam — data model
//
// Dev uses SQLite. To deploy on PostgreSQL, change `provider` below to
// "postgresql" and point DATABASE_URL at your Postgres instance — every model
// here is portable (we avoid Prisma enums / scalar lists, which SQLite lacks,
// using String fields with documented allowed values instead).

generator client {
  provider      = "prisma-client-js"
  // "native" for local dev; the rhel targets cover Netlify Functions (AWS Lambda).
  binaryTargets = ["native", "rhel-openssl-3.0.x", "rhel-openssl-1.0.x"]
}

datasource db {
  provider = "sqlite"
  // The build step (scripts/netlify-db-setup.mjs) sets DATABASE_URL from whichever
  // Netlify DB var is present; at runtime lib/prisma.ts resolves it too.
  url      = env("DATABASE_URL")
}

// ----------------------------- Users -----------------------------

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  avatarUrl    String?
  bio          String?
  homeCountry  String? // e.g. "United States"
  languages    String? // comma-separated, e.g. "en,zh,es"
  role         String   @default("user")   // user | admin
  status       String   @default("active") // active | suspended
  createdAt    DateTime @default(now())

  avgRating    Float    @default(0)
  ratingCount  Int      @default(0)

  reviews            Review[]
  favorites          Favorite[]
  sentMessages       Message[]            @relation("MessageSender")
  conversations      ConversationMember[]
  ownedCommunities   Community[]          @relation("CommunityOwner")
  communityMembers   CommunityMember[]
  hostedMeetups      Meetup[]             @relation("MeetupHost")
  meetupParticipants MeetupParticipant[]
  posts              Post[]               @relation("UserPosts")
  postLikes          PostLike[]
  trips              Trip[]               @relation("UserTrips")
  receivedRatings    UserRating[]         @relation("ReceivedRatings")
  givenRatings       UserRating[]         @relation("GivenRatings")
  preferences        UserPreference[]
  placeInteractions  UserPlaceInteraction[]
  dishReviews        DishReview[]
  foreignerTags      PlaceForeignerTag[]
  reportsMade        Report[]             @relation("ReportsMade")
  moderationActions  ModerationAction[]   @relation("ModActions")
  organizedPools     GroupPool[]          @relation("PoolsOrganized")
  poolMemberships    PoolMember[]

  @@index([email])
  @@index([createdAt])
}

// ----------------------------- Places ----------------------------

model City {
  id          String  @id @default(cuid())
  name        String // 中文名
  nameEn      String // English name
  province    String
  lat         Float
  lng         Float
  summary     String?
  coverImage  String?
  tier        String  @default("THIRD") // MEGA | FIRST | SECOND | THIRD
  isLivable   Boolean @default(false)

  history     String? // 历史介绍
  historyEn   String? // English history
  culture     String? // 文化特色
  cultureEn   String? // English culture
  cuisine     String? // 美食文化
  cuisineEn   String? // English cuisine
  landmarks   String? // 经典景点介绍
  landmarksEn String? // English landmarks
  stories     String? // 典故传说
  storiesEn   String? // English stories

  places      Place[]
  communities Community[]
  meetups     Meetup[]
  posts       Post[]
  trips       Trip[]
  pools       GroupPool[]
}

model Place {
  id          String  @id @default(cuid())
  name        String // 中文名
  nameEn      String // English name
  // category: one of FOOD | ATTRACTION | HOTEL | NATURE | NIGHTLIFE | SHOPPING
  category    String
  cityId      String
  city        City    @relation(fields: [cityId], references: [id])
  address     String?
  lat         Float
  lng         Float
  description String?
  coverImage  String?
  priceLevel  Int     @default(2) // 1..4 ($ .. $$$$)

  // Cached recommendation aggregates (recomputed on each review write).
  avgRating   Float   @default(0)
  reviewCount Int     @default(0)
  weightScore Float   @default(0) // Bayesian-weighted score; sort recommendations by this
  saveCount   Int     @default(0) // cached count of "save" (收藏) favorites; recomputed on each toggle

  createdAt DateTime @default(now())

  reviews            Review[]
  favorites          Favorite[]
  meetups            Meetup[]
  tripStops          TripStop[]
  userInteractions   UserPlaceInteraction[]
  dishes             Dish[]
  foreignerTags      PlaceForeignerTag[]
  pools              GroupPool[]

  @@index([cityId, category])
  @@index([weightScore])
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  placeId   String
  place     Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)
  rating    Int // 1..5
  comment   String?
  hidden    Boolean  @default(false) // hidden by moderation
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tags      ReviewTag[]

  @@unique([userId, placeId]) // one review per user per place (updatable)
  @@index([placeId])
}

model Favorite {
  userId  String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  placeId String
  place   Place  @relation(fields: [placeId], references: [id], onDelete: Cascade)
  // kind: "save" (收藏) | "wish" (想去) — a user can independently mark both.
  kind    String @default("save")

  @@id([userId, placeId, kind])
  @@index([userId, kind])
}

// --------------------------- Messaging ---------------------------

model Conversation {
  id        String   @id @default(cuid())
  isGroup   Boolean  @default(false)
  title     String? // for group chats
  createdAt DateTime @default(now())

  members  ConversationMember[]
  messages Message[]

  @@index([createdAt])
}

model ConversationMember {
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           String       @default("member") // member | admin
  joinedAt       DateTime     @default(now())

  @@id([conversationId, userId])
  @@index([userId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  body           String
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
}

// -------------------- Communities & Meetups ----------------------

model Community {
  id          String   @id @default(cuid())
  name        String
  description String?
  cityId      String?
  city        City?    @relation(fields: [cityId], references: [id])
  ownerId     String
  owner       User     @relation("CommunityOwner", fields: [ownerId], references: [id])
  createdAt   DateTime @default(now())

  members CommunityMember[]
}

model CommunityMember {
  communityId String
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt    DateTime  @default(now())

  @@id([communityId, userId])
}

// Meetup = 搭子 / 拼单 / 拼饭 / 定期活动
model Meetup {
  id          String    @id @default(cuid())
  // type: MEAL (拼饭) | SHOPPING (拼单) | TRIP (搭子/同游) | ACTIVITY (定期活动)
  type        String
  title       String
  description String?
  cityId      String?
  city        City?     @relation(fields: [cityId], references: [id])
  placeId     String?
  place       Place?    @relation(fields: [placeId], references: [id])
  hostId      String
  host        User      @relation("MeetupHost", fields: [hostId], references: [id])
  startTime   DateTime?
  endTime     DateTime?
  maxPeople   Int       @default(4)
  status      String    @default("open") // open | full | closed | cancelled
  // recurrence: none | weekly | monthly
  recurrence  String    @default("none")
  // For recurring meetups: dayOfWeek (1-7, Monday=1) or dayOfMonth (1-31)
  recurrenceDay Int?
  conversationId String? // group chat created for this meetup
  createdAt   DateTime  @default(now())

  participants MeetupParticipant[]

  @@index([status, startTime])
  @@index([cityId, type])
  @@index([hostId])
}

model MeetupParticipant {
  meetupId String
  meetup   Meetup   @relation(fields: [meetupId], references: [id], onDelete: Cascade)
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  status   String   @default("joined") // joined | left
  joinedAt DateTime @default(now())

  @@id([meetupId, userId])
}

// ------------------------- Topics / Hashtags ---------------------

// #话题标签 parsed out of review text. `name` is normalized (lowercased, no #).
model Tag {
  id        String      @id @default(cuid())
  name      String      @unique
  createdAt DateTime    @default(now())

  reviews   ReviewTag[]
  posts     PostTag[]
}

model ReviewTag {
  reviewId String
  review   Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  tagId    String
  tag      Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([reviewId, tagId])
  @@index([tagId])
}

// ----------------------- Community feed (信息流) -----------------------

// A free-form community post (X-style). Text + optional city; #hashtags are
// parsed from `body` into PostTag (reusing the Tag table shared with reviews).
model Post {
  id        String     @id @default(cuid())
  authorId  String
  author    User       @relation("UserPosts", fields: [authorId], references: [id], onDelete: Cascade)
  body      String
  cityId    String?
  city      City?      @relation(fields: [cityId], references: [id])
  likeCount Int        @default(0) // cached; recomputed on each like toggle
  hidden    Boolean    @default(false) // hidden by moderation
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  likes PostLike[]
  tags  PostTag[]

  @@index([createdAt])
  @@index([cityId, createdAt])
}

model PostLike {
  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([postId, userId])
  @@index([userId])
}

model PostTag {
  postId String
  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  tagId  String
  tag    Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@index([tagId])
}

// --------------------------- User Ratings ------------------------

// User rating system (like Facebook) - users can rate each other after meetups
model UserRating {
  id           String   @id @default(cuid())
  raterId      String
  rater        User     @relation("GivenRatings", fields: [raterId], references: [id], onDelete: Cascade)
  ratedId      String
  rated        User     @relation("ReceivedRatings", fields: [ratedId], references: [id], onDelete: Cascade)
  rating       Int      // 1..5 stars
  comment      String?  // Optional feedback
  meetupId     String?  // Optional reference to the meetup where they met
  createdAt    DateTime @default(now())

  @@unique([raterId, ratedId]) // one rating per rater per rated user
  @@index([ratedId])
  @@index([raterId])
}

// --------------------------- User Preferences ------------------------

// User preference tracking for personalized recommendations
model UserPreference {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category    String   // Place category: FOOD | ATTRACTION | HOTEL | NATURE | NIGHTLIFE | SHOPPING
  score       Float    @default(0) // Preference score, higher = more interested
  lastVisited DateTime @default(now())

  @@unique([userId, category])
  @@index([userId])
}

// User place interaction tracking for recommendations
model UserPlaceInteraction {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  placeId     String
  place       Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)
  // type: VIEW | SAVE | WISH | REVIEW | LIKE | VISIT
  type        String
  createdAt   DateTime @default(now())

  @@index([userId, placeId])
  @@index([userId, createdAt])
}

// --------------------------- Trips / 行程 ------------------------

// A user's multi-day itinerary. Stops are places grouped by day number.
model Trip {
  id        String     @id @default(cuid())
  ownerId   String
  owner     User       @relation("UserTrips", fields: [ownerId], references: [id], onDelete: Cascade)
  title     String
  cityId    String?
  city      City?      @relation(fields: [cityId], references: [id])
  createdAt DateTime   @default(now())

  stops TripStop[]

  @@index([ownerId, createdAt])
}

model TripStop {
  id        String   @id @default(cuid())
  tripId    String
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  placeId   String
  place     Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)
  day       Int      @default(1) // 1-based day number within the trip
  note      String?
  createdAt DateTime @default(now())

  @@unique([tripId, placeId]) // a place appears at most once per trip
  @@index([tripId, day])
}

// --------------------- Dishes / 菜品级评价 ----------------------

// A single menu item under a Place (foreigner-facing dish-level reviews).
// Aggregates (avgRating/reviewCount/mustTryCount) are cached and recomputed on
// each DishReview write — mirroring Place's cached aggregates.
model Dish {
  id          String  @id @default(cuid())
  placeId     String
  place       Place   @relation(fields: [placeId], references: [id], onDelete: Cascade)
  name        String // 中文名
  nameEn      String // English name
  description String?
  photoUrl    String?
  priceCents  Int? // optional menu price, in 分 (cents)

  // Cached aggregates (recomputed on each dish-review write).
  avgRating    Float @default(0)
  reviewCount  Int   @default(0)
  mustTryCount Int   @default(0) // how many reviewers flagged "must try"

  createdById String? // who added the dish (for later moderation)
  createdAt   DateTime @default(now())

  reviews     DishReview[]

  @@index([placeId])
  @@index([placeId, avgRating])
}

model DishReview {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dishId    String
  dish      Dish     @relation(fields: [dishId], references: [id], onDelete: Cascade)
  rating    Int // 1..5
  comment   String?
  mustTry   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, dishId]) // one review per user per dish (updatable)
  @@index([dishId])
}

// Community confirmation of a foreigner-friendly attribute for a Place. Each
// user can confirm a given tag for a given place at most once. Counts are
// computed on read (groupBy) rather than cached.
model PlaceForeignerTag {
  placeId   String
  place     Place  @relation(fields: [placeId], references: [id], onDelete: Cascade)
  userId    String
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  // tag: ENGLISH_MENU | PICTURE_MENU | STAFF_ENGLISH | CARD_PAY | MOBILE_PAY | HALAL | VEG_FRIENDLY | ENGLISH_SIGN
  tag       String
  createdAt DateTime @default(now())

  @@id([placeId, userId, tag])
  @@index([placeId, tag])
}

// ----------------------------- Reports ---------------------------

// A user-submitted report against any moderatable entity. Reusable across
// meetups, users, reviews and places — captures the signal now; the moderation
// queue UI is a later iteration (priority ⑤).
model Report {
  id         String   @id @default(cuid())
  reporterId String
  reporter   User     @relation("ReportsMade", fields: [reporterId], references: [id], onDelete: Cascade)
  // targetType: MEETUP | USER | REVIEW | PLACE
  targetType String
  targetId   String
  // reason: SPAM | INAPPROPRIATE | SAFETY | SCAM | OTHER
  reason     String
  detail     String?
  status     String   @default("open") // open | reviewed | dismissed
  createdAt  DateTime @default(now())

  @@unique([reporterId, targetType, targetId]) // one report per user per target
  @@index([targetType, targetId])
  @@index([status])
}

// Audit log: every moderation action a moderator takes, for traceability.
model ModerationAction {
  id          String   @id @default(cuid())
  moderatorId String
  moderator   User     @relation("ModActions", fields: [moderatorId], references: [id], onDelete: Cascade)
  reportId    String? // the report this action resolved, if any
  // action: DISMISS | HIDE_CONTENT | SUSPEND_USER | UNSUSPEND_USER
  action      String
  // targetType: MEETUP | USER | REVIEW | POST | PLACE
  targetType  String
  targetId    String
  note        String?
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([targetType, targetId])
}

// ----------------------- Group Pooling / 拼团 --------------------

// Headcount-based group buy: forms once `targetPeople` join. unitPriceCents is
// informational (per-share price); no real payment in this iteration.
model GroupPool {
  id             String    @id @default(cuid())
  organizerId    String
  organizer      User      @relation("PoolsOrganized", fields: [organizerId], references: [id])
  title          String
  description    String?
  cityId         String?
  city           City?     @relation(fields: [cityId], references: [id])
  placeId        String?
  place          Place?    @relation(fields: [placeId], references: [id])
  productUrl     String?
  unitPriceCents Int? // optional per-person price, in 分 (cents)
  targetPeople   Int // 成团门槛
  maxPeople      Int? // optional cap
  deadline       DateTime?
  status         String    @default("open") // open | formed | closed | cancelled | removed
  conversationId String? // group chat created for this pool
  createdAt      DateTime  @default(now())

  members PoolMember[]

  @@index([status, deadline])
  @@index([cityId])
}

model PoolMember {
  poolId   String
  pool     GroupPool @relation(fields: [poolId], references: [id], onDelete: Cascade)
  userId   String
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  qty      Int       @default(1)
  status   String    @default("joined") // joined | left
  joinedAt DateTime  @default(now())

  @@id([poolId, userId])
}
