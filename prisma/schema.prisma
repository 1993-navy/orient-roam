// Orient Roam — data model
//
// Dev uses SQLite. To deploy on PostgreSQL, change `provider` below to
// "postgresql" and point DATABASE_URL at your Postgres instance — every model
// here is portable (we avoid Prisma enums / scalar lists, which SQLite lacks,
// using String fields with documented allowed values instead).

generator client {
  provider      = "prisma-client-js"
  // "native" for local dev; the rhel targets cover Netlify Functions (AWS Lambda).
  binaryTargets = ["native", "rhel-openssl-3.0.x", "rhel-openssl-1.0.x"]
}

datasource db {
  provider = "postgresql"
  // The build step (scripts/netlify-db-setup.mjs) sets DATABASE_URL from whichever
  // Netlify DB var is present; at runtime lib/prisma.ts resolves it too.
  url      = env("DATABASE_URL")
}

// ----------------------------- Users -----------------------------

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  avatarUrl    String?
  bio          String?
  homeCountry  String? // e.g. "United States"
  languages    String? // comma-separated, e.g. "en,zh,es"
  createdAt    DateTime @default(now())

  reviews            Review[]
  favorites          Favorite[]
  sentMessages       Message[]            @relation("MessageSender")
  conversations      ConversationMember[]
  ownedCommunities   Community[]          @relation("CommunityOwner")
  communityMembers   CommunityMember[]
  hostedMeetups      Meetup[]             @relation("MeetupHost")
  meetupParticipants MeetupParticipant[]
  posts              Post[]               @relation("UserPosts")
  postLikes          PostLike[]
  trips              Trip[]               @relation("UserTrips")
}

// ----------------------------- Places ----------------------------

model City {
  id          String  @id @default(cuid())
  name        String // 中文名
  nameEn      String // English name
  province    String
  lat         Float
  lng         Float
  summary     String?
  coverImage  String?

  places      Place[]
  communities Community[]
  meetups     Meetup[]
  posts       Post[]
  trips       Trip[]
}

model Place {
  id          String  @id @default(cuid())
  name        String // 中文名
  nameEn      String // English name
  // category: one of FOOD | ATTRACTION | HOTEL | NATURE | NIGHTLIFE | SHOPPING
  category    String
  cityId      String
  city        City    @relation(fields: [cityId], references: [id])
  address     String?
  lat         Float
  lng         Float
  description String?
  coverImage  String?
  priceLevel  Int     @default(2) // 1..4 ($ .. $$$$)

  // Cached recommendation aggregates (recomputed on each review write).
  avgRating   Float   @default(0)
  reviewCount Int     @default(0)
  weightScore Float   @default(0) // Bayesian-weighted score; sort recommendations by this

  createdAt DateTime @default(now())

  reviews   Review[]
  favorites Favorite[]
  meetups   Meetup[]
  tripStops TripStop[]

  @@index([cityId, category])
  @@index([weightScore])
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  placeId   String
  place     Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)
  rating    Int // 1..5
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tags      ReviewTag[]

  @@unique([userId, placeId]) // one review per user per place (updatable)
  @@index([placeId])
}

model Favorite {
  userId  String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  placeId String
  place   Place  @relation(fields: [placeId], references: [id], onDelete: Cascade)
  // kind: "save" (收藏) | "wish" (想去) — a user can independently mark both.
  kind    String @default("save")

  @@id([userId, placeId, kind])
  @@index([userId, kind])
}

// --------------------------- Messaging ---------------------------

model Conversation {
  id        String   @id @default(cuid())
  isGroup   Boolean  @default(false)
  title     String? // for group chats
  createdAt DateTime @default(now())

  members  ConversationMember[]
  messages Message[]
}

model ConversationMember {
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           String       @default("member") // member | admin
  joinedAt       DateTime     @default(now())

  @@id([conversationId, userId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  body           String
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
}

// -------------------- Communities & Meetups ----------------------

model Community {
  id          String   @id @default(cuid())
  name        String
  description String?
  cityId      String?
  city        City?    @relation(fields: [cityId], references: [id])
  ownerId     String
  owner       User     @relation("CommunityOwner", fields: [ownerId], references: [id])
  createdAt   DateTime @default(now())

  members CommunityMember[]
}

model CommunityMember {
  communityId String
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt    DateTime  @default(now())

  @@id([communityId, userId])
}

// Meetup = 搭子 / 拼单 / 拼饭
model Meetup {
  id          String    @id @default(cuid())
  // type: MEAL (拼饭) | SHOPPING (拼单) | TRIP (搭子/同游)
  type        String
  title       String
  description String?
  cityId      String?
  city        City?     @relation(fields: [cityId], references: [id])
  placeId     String?
  place       Place?    @relation(fields: [placeId], references: [id])
  hostId      String
  host        User      @relation("MeetupHost", fields: [hostId], references: [id])
  startTime   DateTime?
  maxPeople   Int       @default(4)
  status      String    @default("open") // open | full | closed
  createdAt   DateTime  @default(now())

  participants MeetupParticipant[]
}

model MeetupParticipant {
  meetupId String
  meetup   Meetup   @relation(fields: [meetupId], references: [id], onDelete: Cascade)
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  status   String   @default("joined") // joined | left
  joinedAt DateTime @default(now())

  @@id([meetupId, userId])
}

// ------------------------- Topics / Hashtags ---------------------

// #话题标签 parsed out of review text. `name` is normalized (lowercased, no #).
model Tag {
  id        String      @id @default(cuid())
  name      String      @unique
  createdAt DateTime    @default(now())

  reviews   ReviewTag[]
  posts     PostTag[]
}

model ReviewTag {
  reviewId String
  review   Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  tagId    String
  tag      Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([reviewId, tagId])
  @@index([tagId])
}

// ----------------------- Community feed (信息流) -----------------------

// A free-form community post (X-style). Text + optional city; #hashtags are
// parsed from `body` into PostTag (reusing the Tag table shared with reviews).
model Post {
  id        String     @id @default(cuid())
  authorId  String
  author    User       @relation("UserPosts", fields: [authorId], references: [id], onDelete: Cascade)
  body      String
  cityId    String?
  city      City?      @relation(fields: [cityId], references: [id])
  likeCount Int        @default(0) // cached; recomputed on each like toggle
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  likes PostLike[]
  tags  PostTag[]

  @@index([createdAt])
  @@index([cityId, createdAt])
}

model PostLike {
  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([postId, userId])
  @@index([userId])
}

model PostTag {
  postId String
  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  tagId  String
  tag    Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@index([tagId])
}

// --------------------------- Trips / 行程 ------------------------

// A user's multi-day itinerary. Stops are places grouped by day number.
model Trip {
  id        String     @id @default(cuid())
  ownerId   String
  owner     User       @relation("UserTrips", fields: [ownerId], references: [id], onDelete: Cascade)
  title     String
  cityId    String?
  city      City?      @relation(fields: [cityId], references: [id])
  createdAt DateTime   @default(now())

  stops TripStop[]

  @@index([ownerId, createdAt])
}

model TripStop {
  id        String   @id @default(cuid())
  tripId    String
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  placeId   String
  place     Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)
  day       Int      @default(1) // 1-based day number within the trip
  note      String?
  createdAt DateTime @default(now())

  @@unique([tripId, placeId]) // a place appears at most once per trip
  @@index([tripId, day])
}
