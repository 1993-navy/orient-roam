# Copy this file to .env and fill in the values.

# --- Database ---
# Dev uses SQLite (no setup). For production, switch the provider in
# prisma/schema.prisma to "postgresql" and set a Postgres URL here, e.g.
# DATABASE_URL="postgresql://user:pass@host:5432/orient_roam?schema=public"
DATABASE_URL="file:./dev.db"

# --- Auth.js (NextAuth v5) ---
# Generate with: npx auth secret
AUTH_SECRET="replace-with-a-32-char-random-secret"

# --- Amap / 高德地图 (Web JS API key) ---
# https://console.amap.com/dev/key/app  -> create a key of type "Web端(JS API)"
# Optional but recommended; without it the app shows a placeholder map.
NEXT_PUBLIC_AMAP_KEY=""
NEXT_PUBLIC_AMAP_SECURITY_CODE=""
