# Copy this file to .env and fill in the values.

# --- Database ---
# Datasource is PostgreSQL (prisma/schema.prisma). Use a local or hosted Postgres
# for development; production injects Neon's URL via scripts/netlify-db-setup.mjs.
DATABASE_URL="postgresql://user:pass@localhost:5432/orient_roam?schema=public"

# --- Auth.js (NextAuth v5) ---
# Generate with: npx auth secret
AUTH_SECRET="replace-with-a-32-char-random-secret"

# --- Amap / 高德地图 (Web JS API key) ---
# https://console.amap.com/dev/key/app  -> create a key of type "Web端(JS API)"
# Optional but recommended; without it the app shows a placeholder map.
NEXT_PUBLIC_AMAP_KEY=""
NEXT_PUBLIC_AMAP_SECURITY_CODE=""

# --- AI content moderation (自动内容审核) ---
# Optional. When configured, user-published places / diaries / media captions
# are screened by an LLM (on top of the keyword filter) before entering the
# human review queue. Uses any OpenAI-compatible Chat Completions API.
# Leave MODERATION_AI_API_KEY empty to disable — publishing still works and
# falls back to the keyword-only filter (fail-open).
MODERATION_AI_API_KEY=""
# Base URL of the OpenAI-compatible endpoint (no trailing /chat/completions).
# Examples: OpenAI https://api.openai.com/v1
#           DeepSeek https://api.deepseek.com/v1
#           Moonshot https://api.moonshot.cn/v1
MODERATION_AI_BASE_URL="https://api.openai.com/v1"
# Model name to use for classification.
MODERATION_AI_MODEL="gpt-4o-mini"
# Optional. Set to "off" / "0" / "false" to disable even when a key is present.
MODERATION_AI="on"
# Optional. Per-request timeout in milliseconds (default 8000).
MODERATION_AI_TIMEOUT_MS="8000"

